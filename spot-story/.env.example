# Spot Story MCP Server Configuration
# Copy this file to .env and fill in your values

# ============================================================================
# Server Configuration
# ============================================================================
MCP_HOST=0.0.0.0
MCP_PORT=8004

# ============================================================================
# Azure OpenAI Configuration
# ============================================================================
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your-api-key-here
AZURE_OPENAI_API_VERSION=2025-01-01-preview

# Model Deployments
AZURE_DEPLOYMENT_GPT4_1=gpt-4-1
AZURE_DEPLOYMENT_GPT4O=gpt-4o

# ============================================================================
# Reuters API Configuration
# ============================================================================
REUTERS_API_KEY=your-api-key-here

# ============================================================================
# Optional: Azure AD Authentication (if not using API key)
# ============================================================================
# AZURE_TENANT_ID=your-tenant-id
# AZURE_CLIENT_ID=your-client-id
# AZURE_CLIENT_SECRET=your-client-secret


ORCHESTRATOR_ENDPOINT=https://llmproxy-ha.int.thomsonreuters.com
ORCHESTRATOR_API_VERSION=2025-01-01-preview

