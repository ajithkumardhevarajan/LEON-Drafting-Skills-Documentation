# Story Drafting MCP Server Configuration
# ============================================================================
#
# LOCAL DEVELOPMENT - Just run one command!
#
#   ./run-docker-local.sh
#
# This script automatically:
#   - Fetches JFrog credentials from AWS SSM
#   - Builds the Docker image
#   - Fetches secrets from AWS Secrets Manager at startup
#   - Runs the container on port 8004
#
# Prerequisites:
#   1. AWS CLI configured
#   2. Login with cloud-tool:
#      cloud-tool login -u 'mgmt\mEmpId' -p 'vault_password' \
#        --account-id '060725138335' --role 'human-role/a207920-PowerUser2'
#
# Test:
#   curl http://localhost:8004/health
#
# ============================================================================

# ============================================================================
# Server Configuration
# ============================================================================
MCP_HOST=0.0.0.0
MCP_PORT=8004

# ============================================================================
# AWS Configuration (for local development)
# ============================================================================
AWS_REGION=eu-west-1
AWS_PROFILE=tr-central-preprod
SECRET_NAME=a207920-leon-skills

# ============================================================================
# The following are AUTOMATICALLY FETCHED from AWS Secrets Manager.
# You don't need to set these - they're listed here for documentation only.
# ============================================================================

# LLM Orchestrator (fetched from AWS)
# ORCHESTRATOR_ENDPOINT=https://llmproxy-ha.int.thomsonreuters.com
# LEON_ORCHESTRATOR_API_KEY=...
# LEON_ORCHESTRATOR_TENANT_ID=...
# LEON_ORCHESTRATOR_CLIENT_ID=...
# LEON_ORCHESTRATOR_CLIENT_SECRET=...
# LEON_ORCHESTRATOR_RESOURCE=...

# Reuters API (fetched from AWS)
# REUTERS_API_KEY=...

# Model Deployments (defaults, can override)
AZURE_DEPLOYMENT_GPT4_1=gpt-4-1
AZURE_DEPLOYMENT_GPT4O=gpt-4o
AZURE_DEPLOYMENT_GEMINI_2_5_PRO=gemini-2-5-pro
