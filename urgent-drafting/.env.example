# Urgent Drafting MCP Server Configuration
# Copy this file to .env and adjust values as needed

# Server host (default: 0.0.0.0)
MCP_HOST=0.0.0.0

# Server port (default: 8000)
MCP_PORT=8000

# Add any tool-specific configuration variables below
# For production-ready urgent drafting, you might need:
#
# News API credentials
# NEWS_API_KEY=your-news-api-key-here
# REUTERS_WIRE_API_URL=https://api.reuters.com/wire
#
# LLM/AI service credentials (for content generation)
# OPENAI_API_KEY=your-openai-key-here
# ANTHROPIC_API_KEY=your-anthropic-key-here
#
# Database connections (for story context)
# DATABASE_URL=postgresql://user:pass@host:port/db
# REDIS_URL=redis://localhost:6379/0
#
# Editorial guidelines and style guide locations
# STYLE_GUIDE_URL=https://internal.reuters.com/style-guide
# FACT_CHECK_API_URL=https://internal.reuters.com/fact-check
