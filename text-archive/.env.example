# Text Archive MCP Server Configuration
# ============================================================================
#
# LOCAL DEVELOPMENT - Copy this file to .env and configure credentials
#
#   cp .env.example .env
#
# Then set the Reuters Text Archive credentials in .env before running.
#
# Run locally:
#   MCP_PORT=8005 python run.py
#
# Test:
#   curl http://localhost:8005/health
#
# ============================================================================

# ============================================================================
# Server Configuration
# ============================================================================
MCP_HOST=0.0.0.0
MCP_PORT=8005

# ============================================================================
# AWS Configuration (for local development)
# ============================================================================
AWS_REGION=eu-west-1
AWS_PROFILE=tr-central-preprod
SECRET_NAME=a207920-leon-skills

# ============================================================================
# Reuters Text Archive API credentials
# These are fetched from AWS Secrets Manager in production.
# For local development, set them directly here.
# ============================================================================
# REUTERS_ARCHIVE_CLIENT_ID=your_client_id_here
# REUTERS_ARCHIVE_CLIENT_SECRET=your_client_secret_here
